rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each signed-in user can only read/write their own profile doc
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Each signed-in user can only read/write their own cart
    match /carts/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Each signed-in user can only read/write their own wishlist
    match /wishlists/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Orders: anyone can create an order (guest checkout supported),
    // but only the owner can read it, and clients can only update it
    // (e.g. marking a Stripe session as paid) if they own it. Deletion
    // is blocked entirely — cancel via status change instead.
    match /orders/{orderId} {
      allow create: if request.resource.data.uid == null
                     || (request.auth != null && request.auth.uid == request.resource.data.uid);
      allow read, update: if request.auth != null && request.auth.uid == resource.data.uid;
      allow delete: if false;
    }
  }
}
